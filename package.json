{
  "name": "@permitplace/permit-conductor",
  "version": "0.1.0",
  "description": "Permit workflow orchestration engine — stateful 7-stage permit journey with GOAP correction handling",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./api": {
      "import": "./dist/esm/api/index.js",
      "require": "./dist/cjs/api/index.js",
      "types": "./dist/types/api/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "pack:dry-run": "npm pack --dry-run",
    "validate:types": "node scripts/validate-types.mjs",
    "test": "jest --coverage --config=jest.config.ts",
    "test:watch": "jest --watch --config=jest.config.ts",
    "lint": "eslint src tests --ext .ts",
    "typecheck": "tsc --noEmit",
    "benchmark": "ts-node tests/benchmark/runner.ts"
  },
  "keywords": [
    "permits",
    "workflow",
    "orchestration",
    "goap",
    "state-machine"
  ],
  "author": "PermitPlace <engineering@permitplace.com>",
  "license": "MIT",
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "pg": ">=8.0.0",
    "better-sqlite3": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true },
    "better-sqlite3": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^9.0.0",
    "better-sqlite3": "^9.4.0",
    "express": "^4.18.0",
    "jest": "^29.5.0",
    "pg": "^8.11.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
